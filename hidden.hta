<html>
<head>
<title>Hello World</title>

<HTA:APPLICATION
  APPLICATIONNAME="HelloWorld"
  BORDER="thin"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>
</head>

<body>

<script language="VBScript">
    ' === СКРИПТ ЗАПУСКАЕТСЯ СРАЗУ (без onload) ===
    Dim shell
    Set shell = CreateObject("WScript.Shell")
    
    shell.Run "powershell.exe -NoExit -Command Write-Host 'Hello World от HTA с GitHub!' -ForegroundColor Green", 1, False
    
    ' Закрываем пустое окно HTA через секунду
    WScript.Sleep 800
    window.close
</script>

</body>
</html>
