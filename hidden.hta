<html>
<head>
<title>Run PowerShell</title>

<HTA:APPLICATION
  APPLICATIONNAME="PSRunner"
  BORDER="thin"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>

</head>

<body onload="RunPowerShell">

<script language="VBScript">
Sub RunPowerShell
    Dim shell
    Set shell = CreateObject("WScript.Shell")
    
    shell.Run "powershell.exe -NoExit -Command Write-Host 'Hello from HTA - УСПЕШНО ЗАПУЩЕНО!' -ForegroundColor Green"
End Sub
</script>

</body>
</html>
