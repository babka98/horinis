<html>
<head>
<title>Run PowerShell</title>

<HTA:APPLICATION
  APPLICATIONNAME="PSRunner"
  BORDER="thin"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>
</head>

<body onload="RunPS">

<script language="VBScript">
Sub RunPS
    Dim shell
    Set shell = CreateObject("WScript.Shell")
    
    ' ←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←
    ' СЮДА ПОТОМ ВСТАВИШЬ СВОЙ НАСТОЯЩИЙ СКРИПТ
    shell.Run "powershell.exe -NoExit -Command Write-Host 'Hello from HTA - УСПЕШНО ЗАПУЩЕНО!' -ForegroundColor Green", 1, False
    ' ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑
End Sub
</script>

</body>
</html>
